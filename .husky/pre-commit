#!/bin/sh

echo "рҹ§‘вҖҚрҹ’» Running lint-staged..."
npx lint-staged

STATUS=$?
if [ "$STATUS" -eq 1 ]; then
  echo "рҹ‘®вҖҚвҷӮпёҸ Commit blocked: Lint errors found in staged files рҹҡЁ"
  echo "рҹӣ пёҸ Fix them before committing рҹӨ–"
  exit 1
elif [ "$STATUS" -ne 0 ]; then
  echo "рҹ’Ҙ Unexpected error from lint-staged"
  exit $STATUS
fi

echo "рҹҺү No errors found. Let it go... рҹҡҖ"
exit 0
